# Zsh environment — sourced for every shell (login, interactive, script)

# XDG directories
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# Homebrew — guard against re-activation in nested shells (avoids PATH dupes)
if [ -z "${HOMEBREW_PREFIX-}" ]; then
{{- if eq .chezmoi.os "darwin" }}
    for brew_bin in /opt/homebrew/bin/brew /usr/local/bin/brew; do
        if [ -x "$brew_bin" ]; then
            eval "$("$brew_bin" shellenv)"
            break
        fi
    done
    unset brew_bin
{{- else if eq .chezmoi.os "linux" }}
    if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    fi
{{- end }}
fi

# User bin (idempotent)
case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
esac

# dotbot
case ":$PATH:" in
    *":$HOME/dotbot/bin:"*) ;;
    *) export PATH="$HOME/dotbot/bin:$PATH" ;;
esac

# Non-secret environment
if [ -r "$XDG_CONFIG_HOME/shell/env.sh" ]; then
    . "$XDG_CONFIG_HOME/shell/env.sh"
fi

# Local secrets (intentionally unmanaged by chezmoi)
if [ -r "$XDG_CONFIG_HOME/shell/secrets.sh" ]; then
    . "$XDG_CONFIG_HOME/shell/secrets.sh"
fi
