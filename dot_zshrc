# Zsh interactive shell configuration.

export ZSH="${ZSH:-$HOME/.oh-my-zsh}"
ZSH_THEME=""
DISABLE_AUTO_UPDATE="true"

plugins=(
    git
    zsh-autosuggestions
    zsh-syntax-highlighting
)

if [ -r "$ZSH/oh-my-zsh.sh" ]; then
    source "$ZSH/oh-my-zsh.sh"
fi

if command -v mise >/dev/null 2>&1; then
    eval "$(mise activate zsh)"
fi

if command -v starship >/dev/null 2>&1; then
    eval "$(starship init zsh)"
fi

if command -v zoxide >/dev/null 2>&1; then
    eval "$(zoxide init zsh)"
fi

alias ls="eza -lh --icons --group-directories-first"
alias ll="eza -lh --icons --group-directories-first"
alias la="eza -lah --icons --group-directories-first"
alias lt="eza --tree --level=2 --icons"
alias vim="nvim"
alias cc="claude --dangerously-skip-permissions"
alias c="codex --yolo"
alias clb='c -c '\''model_providers.codex-lb={name="OpenAI", base_url="https://codex.braga.cloud/backend-api/codex", wire_api="responses", supports_websockets=true, requires_openai_auth=false}'\'' -c model_provider=codex-lb'

temp() {
    local temp
    temp=$(ioreg -rn AppleSmartBattery | awk -F'= ' '/"Temperature"/ {print $2; exit}')
    awk "BEGIN {printf \"Battery: %.1f C\n\", ($temp / 10) - 273.15}"
}

tmp() {
    local dir
    dir="$(mktemp -d)" || return
    cd "$dir" || return
    print -r -- "$dir"
}
