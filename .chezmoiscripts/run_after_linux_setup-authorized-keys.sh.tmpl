#!/usr/bin/env bash
set -euo pipefail

github_user={{ default "carlospedreira" (get . "githubUser") | quote }}
ssh_dir="$HOME/.ssh"
authorized_keys="$ssh_dir/authorized_keys"
begin_marker="# chezmoi-github-keys begin ${github_user}"
end_marker="# chezmoi-github-keys end ${github_user}"

if [[ ! "$github_user" =~ ^[A-Za-z0-9][A-Za-z0-9-]{0,38}$ ]]; then
    echo "Invalid GitHub username: $github_user" >&2
    exit 1
fi

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

raw_keys="$tmp_dir/github.keys.raw"
github_keys="$tmp_dir/github.keys"
authorized_keys_without_github="$tmp_dir/authorized_keys.without-github"
authorized_keys_next="$tmp_dir/authorized_keys.next"
keys_url="https://github.com/${github_user}.keys"

if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$keys_url" -o "$raw_keys"
elif command -v wget >/dev/null 2>&1; then
    wget -qO "$raw_keys" "$keys_url"
else
    echo "curl or wget is required to fetch GitHub SSH keys" >&2
    exit 1
fi

awk '
    /^(ssh-(rsa|ed25519)|ecdsa-sha2-nistp(256|384|521)|sk-ssh-ed25519@openssh.com|sk-ecdsa-sha2-nistp256@openssh.com)[[:space:]]/ && !seen[$0]++
' "$raw_keys" >"$github_keys"

if [[ -s "$raw_keys" && ! -s "$github_keys" ]]; then
    echo "No valid SSH public keys found at $keys_url" >&2
    exit 1
fi

mkdir -p "$ssh_dir"
chmod 700 "$ssh_dir"

if [[ -f "$authorized_keys" ]]; then
    awk -v begin="$begin_marker" -v end="$end_marker" '
        $0 == begin { skip = 1; next }
        $0 == end { skip = 0; next }
        !skip { print }
    ' "$authorized_keys" >"$authorized_keys_without_github"
else
    : >"$authorized_keys_without_github"
fi

{
    if [[ -s "$authorized_keys_without_github" ]]; then
        cat "$authorized_keys_without_github"
        if [[ -n "$(tail -c 1 "$authorized_keys_without_github")" ]]; then
            echo
        fi
        echo
    fi

    echo "$begin_marker"
    cat "$github_keys"
    echo "$end_marker"
} >"$authorized_keys_next"

mv "$authorized_keys_next" "$authorized_keys"
chmod 600 "$authorized_keys"
