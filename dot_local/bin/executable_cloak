#!/usr/bin/env bash
set -euo pipefail

item_name="${CLOAK_BITWARDEN_ITEM:-cloak}"

usage() {
    printf 'usage: cloak command [args...]\n' >&2
    printf '       cloak --export\n' >&2
}

require_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        printf 'cloak: required command not found: %s\n' "$1" >&2
        exit 1
    fi
}

bitwarden_status() {
    bw status 2>/dev/null | jq -r '.status'
}

unlock_bitwarden() {
    local status

    status="$(bitwarden_status || true)"

    case "$status" in
        unlocked)
            if [ -n "${BW_SESSION:-}" ]; then
                printf '%s\n' "$BW_SESSION"
            fi
            ;;
        locked)
            bw unlock --raw
            ;;
        unauthenticated)
            printf 'cloak: Bitwarden CLI is not logged in. Run `bw login` first.\n' >&2
            exit 1
            ;;
        *)
            printf 'cloak: unable to determine Bitwarden CLI status.\n' >&2
            exit 1
            ;;
    esac
}

get_item() {
    if [ -n "$session" ]; then
        export BW_SESSION="$session"
        bw get item "$item_name" --session "$session"
    else
        bw get item "$item_name"
    fi
}

export_secrets() {
    local secrets_file secrets_dir temp_file

    secrets_file="${XDG_CONFIG_HOME:-$HOME/.config}/shell/secrets.sh"
    secrets_dir="$(dirname "$secrets_file")"

    mkdir -p "$secrets_dir"
    temp_file="$(mktemp "$secrets_dir/.secrets.sh.XXXXXX")"

    {
        printf '# Generated by cloak from Bitwarden item "%s"\n' "$item_name"
        get_item |
            jq -r '
                .fields[]?
                | select(.name | test("^[A-Za-z_][A-Za-z0-9_]*$"))
                | "export \(.name)=\((.value // "") | @sh)"
            '
    } >"$temp_file"

    chmod 600 "$temp_file"
    mv "$temp_file" "$secrets_file"
    printf 'cloak: exported %s\n' "$secrets_file" >&2
}

if [ "$#" -eq 0 ]; then
    usage
    exit 2
fi

export_secrets_file=0
if [ "${1:-}" = "--export" ]; then
    export_secrets_file=1
    shift
fi

require_command bw
require_command jq

session="$(unlock_bitwarden)"

if [ "$export_secrets_file" -eq 1 ]; then
    if [ "$#" -ne 0 ]; then
        usage
        exit 2
    fi

    export_secrets
    exit 0
fi

if [ "$#" -eq 0 ]; then
    usage
    exit 2
fi

env_args=()
while IFS= read -r -d '' name && IFS= read -r -d '' value; do
    env_args+=("$name=$value")
done < <(
    get_item |
        jq -j '
            .fields[]?
            | select(.name | test("^[A-Za-z_][A-Za-z0-9_]*$"))
            | .name, "\u0000", (.value // ""), "\u0000"
        '
)

if [ "${#env_args[@]}" -gt 0 ]; then
    exec env "${env_args[@]}" "$@"
else
    exec "$@"
fi
