#!/usr/bin/env sh
set -eu

cloak_file="${HOME}/.config/shell/cloak.sh"

if [ "$#" -eq 0 ]; then
    printf 'usage: cloak command [args...]\n' >&2
    exit 2
fi

if [ ! -r "$cloak_file" ]; then
    printf 'cloak file not found or not readable: %s\n' "$cloak_file" >&2
    exit 1
fi

set -a
. "$cloak_file"
set +a

exec "$@"
