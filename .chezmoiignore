*.md
.dockerignore
.devcontainer

{{- $kernelOSRelease := lower (default "" (get .chezmoi.kernel "osrelease")) }}
{{- $kernelVersion := lower (default "" (get .chezmoi.kernel "version")) }}
{{- $isWSL := and (eq .chezmoi.os "linux") (or (contains "microsoft" $kernelOSRelease) (contains "microsoft" $kernelVersion)) }}

{{- if eq (get . "profile") "container" }}
/.chezmoiscripts/all_setup-devpod.sh
/.chezmoiscripts/all_setup-ssh.sh
/.chezmoiscripts/linux_install-devpod.sh
/.chezmoiscripts/linux_install-docker.sh
/.chezmoiscripts/linux_install-tailscale.sh
/.chezmoiscripts/linux_setup-docker.sh
/.config/ghostty/config
/.ssh/config
{{- end }}

{{- if ne .chezmoi.os "linux" }}
/.chezmoiscripts/linux_*
{{- end }}

{{- if not $isWSL }}
/.chezmoiscripts/wsl_*
{{- end }}

{{- if ne .chezmoi.os "darwin" }}
/.chezmoiscripts/darwin_*
/.config/homebrew/
{{- end }}
