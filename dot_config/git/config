[user]
    name = Carlos Pedreira
    email = carlospedreira@users.noreply.github.com
[gpg]
    format = ssh
[gpg "ssh"]
    defaultKeyCommand = sh -c \"ssh-add -L | sed -n '/^ssh-ed25519 /p' | head -n 1 | sed 's/^/key::/'\"
[commit]
    gpgsign = true
[tag]
    gpgsign = true
[init]
    defaultBranch = main
[push]
    autoSetupRemote = true
[includeIf "gitdir:~/Developer/az/"]
    path = ~/Developer/az/.gitconfig
[includeIf "gitdir/i:D:/az/"]
    path = D:/az/.gitconfig
